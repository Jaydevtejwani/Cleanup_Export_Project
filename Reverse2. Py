import pandas as pd

# Excel read
df = pd.read_excel("input.xlsx")
df = df.rename(columns={"Full Name": "name"})

# normalize function
def normalize(x):
    return ' '.join(sorted(str(x).lower().strip().split()))

df['key'] = df['name'].apply(normalize)

# group
g = df.groupby('key')['name'].apply(list).reset_index()

# only pairs (duplicates)
g = g[g['name'].apply(len) > 1]

# convert into side-by-side pairs
rows = []
for names in g['name']:
    for i in range(len(names)):
        for j in range(i + 1, len(names)):
            rows.append({
                "name_1": names[i],
                "name_2": names[j]
            })

result = pd.DataFrame(rows)

print(result)

# optional save
result.to_excel("name_pairs.xlsx", index=False)
